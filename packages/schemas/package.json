{
  "name": "@kassa/schemas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Shared Zod request/response schemas for the Kassa API. Consumed by @kassa/api and the PWA.",
  "license": "AGPL-3.0-or-later",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js"
    },
    "./eod": {
      "types": "./dist/eod.d.ts",
      "import": "./dist/eod.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./merchant": {
      "types": "./dist/merchant.d.ts",
      "import": "./dist/merchant.js"
    },
    "./payments": {
      "types": "./dist/payments.d.ts",
      "import": "./dist/payments.js"
    },
    "./reconciliation": {
      "types": "./dist/reconciliation.d.ts",
      "import": "./dist/reconciliation.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
