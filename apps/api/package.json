{
  "name": "@kassa/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Kassa API server — Fastify + TypeScript.",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./app.js": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    },
    "./services/sales/index.js": {
      "types": "./dist/services/sales/index.d.ts",
      "default": "./dist/services/sales/index.js"
    },
    "./services/outlets/index.js": {
      "types": "./dist/services/outlets/index.d.ts",
      "default": "./dist/services/outlets/index.js"
    },
    "./services/catalog/index.js": {
      "types": "./dist/services/catalog/index.d.ts",
      "default": "./dist/services/catalog/index.js"
    },
    "./services/enrolment/index.js": {
      "types": "./dist/services/enrolment/index.d.ts",
      "default": "./dist/services/enrolment/index.js"
    },
    "./services/eod/index.js": {
      "types": "./dist/services/eod/index.d.ts",
      "default": "./dist/services/eod/index.js"
    },
    "./auth/staff-bootstrap.js": {
      "types": "./dist/auth/staff-bootstrap.d.ts",
      "default": "./dist/auth/staff-bootstrap.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-migrations.mjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "tsx ./node_modules/drizzle-kit/bin.cjs generate --config=./drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "tsx ./node_modules/drizzle-kit/bin.cjs studio --config=./drizzle.config.ts",
    "seed:pilot": "tsx ../../scripts/seed-pilot.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@kassa/payments": "workspace:*",
    "@kassa/schemas": "workspace:*",
    "@sentry/node": "^8.50.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.76.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.10.1",
    "pg": "8.14.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "8.15.3",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
