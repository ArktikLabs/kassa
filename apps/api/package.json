{
  "name": "@kassa/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Kassa API server — Fastify + TypeScript.",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@kassa/payments": "workspace:*",
    "@kassa/schemas": "workspace:*",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
