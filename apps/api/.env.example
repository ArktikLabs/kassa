NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Midtrans (QRIS payments). Leave unset locally to disable the /v1/payments/* routes
# (they will respond 503 payments_unavailable). In CI/staging, source the sandbox
# server key from secrets, never commit it.
# MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXXXXXXXXXX
MIDTRANS_ENVIRONMENT=sandbox

# BullMQ broker for the worker process group. Leave unset locally to skip the
# Redis bootstrap (the worker logs and idles instead). For staging/production,
# Fly secrets bind a per-environment Upstash URL — see docs/CI-CD.md §3.10.
# REDIS_URL=redis://default:password@localhost:6379
